{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "my-catalog/catalog-notice",
  "version": "0.1.0",
  "title": "Catalog Notice",
  "category": "widgets",
  "icon": "products",
  "description": "A starter block for the My Catalog plugin.",
  "textdomain": "my-catalog",
  "editorScript": "file:./build/index.js",
  "editorStyle": "file:./build/index.css",
  "style": "file:./build/style-index.css",
  "supports": {
    "html": false
  },
  "attributes": {
    "message": {
      "type": "string",
      "default": "Build your catalog blocks here."
    }
  }
}
